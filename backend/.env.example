# Copy thành .env và điền giá trị thật (.env nằm trong .gitignore)
NODE_ENV=development
PORT=3000

# PostgreSQL (marketing data)
DATABASE_URL=postgres://mpt:mpt_secret@localhost:5432/mpt_marketing

# Redis (queue job)
REDIS_HOST=localhost
REDIS_PORT=6379

# FastAPI video pipeline — chạy local thì localhost, trong docker thì http://fastapi:8080
FASTAPI_URL=http://localhost:8080

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
