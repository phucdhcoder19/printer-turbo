# Copy thành .env và điền giá trị thật (.env nằm trong .gitignore)
NODE_ENV=development
PORT=3000

# PostgreSQL (marketing data)
DATABASE_URL=postgres://mpt:mpt_secret@localhost:5432/mpt_marketing

# Redis (queue job)
REDIS_HOST=localhost
REDIS_PORT=6379

# FastAPI video pipeline — chạy local thì localhost, trong docker thì http://fastapi:8080
FASTAPI_URL=http://localhost:8080

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Frontend (callback OAuth redirect về đây sau khi kết nối kênh)
FRONTEND_URL=http://localhost:5173

# Mã hoá token nền tảng (AES-256). Sinh key: openssl rand -hex 32
# Bắt buộc khi kết nối thật (Facebook/TikTok/WordPress); mock connect không cần.
ENCRYPTION_KEY=

# ---- Facebook OAuth ----
# Tạo app tại https://developers.facebook.com → lấy App ID/Secret,
# whitelist redirect URI bên dưới trong Facebook Login settings.
FB_APP_ID=
FB_APP_SECRET=
FB_REDIRECT_URI=http://localhost:3000/api/social-accounts/facebook/callback
# Scope khi kết nối. Mặc định chỉ liệt kê Page (không cần App Review).
# Để ĐĂNG BÀI lên Page sau này (cần App Review): public_profile,pages_show_list,pages_manage_posts,pages_read_engagement
FB_SCOPES=public_profile,pages_show_list

# ---- TikTok OAuth (Login Kit v2) ----
# Tạo app tại https://developers.tiktok.com → Client Key/Secret, scope user.info.basic.
# Lưu ý: TikTok thường yêu cầu redirect HTTPS (không nhận http://localhost) →
# khi test thật dùng tunnel (ngrok) và cập nhật TIKTOK_REDIRECT_URI cho khớp.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/api/social-accounts/tiktok/callback
